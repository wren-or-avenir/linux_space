# 目标信息消息定义
float32 x             # 目标中心点 x 坐标（归一化 -1.0~1.0，0.0=图像中心）
float32 y             # 目标中心点 y 坐标（归一化 -1.0~1.0，0.0=图像中心）
float32 width         # 目标宽度（归一化 0.0~1.0）
float32 height        # 目标高度（归一化 0.0~1.0）
float32 confidence    # 置信度 0.0-1.0（0.0=丢失，>0.1=检测到）
int32 target_type     # 0=简单色块，1=装甲板